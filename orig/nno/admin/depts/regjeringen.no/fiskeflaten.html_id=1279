        <div class="ArticleView"> 
            
            <div class="ArticleContent">
                <h2>
                    <a href="/nn/dep/fkd/aktuelt/taler_artikler/ovrig_politisk_ledelse/statssekretar-vidar-ulriksen/2010/ressursforvaltning-og-reguleringar-i-fra.html?id=615351" title="">
