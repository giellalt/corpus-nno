            <h2>
                <a href="/nn/dep/jd/Om-departementet/Organisasjon/Avdelingar/Lovavdelinga.html?id=1444" title="">
                    Lovavdelinga
                </a>
            </h2>
            <h3 class="subDescription" style="display:none"></h3>
            
            <p>
