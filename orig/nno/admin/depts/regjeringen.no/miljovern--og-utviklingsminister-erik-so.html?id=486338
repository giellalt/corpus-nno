<p align="left"><b>Politiske verv</b></p><b style="mso-bidi-font-weight: normal"></b></div>
<table cellspacing="0" cellpadding="0" border="0">
<tbody>
<tr valign="top">
<td>
<p>2007-</p></td>
<td>
<p>Miljø- og utviklingsminister, Jens Stoltenbergs andre regjering</p></td></tr>
<tr>
<td class="contents" valign="top" width="140">
<p align="left">2005-2007</p></td>
<td class="contents" valign="top" width="455">
<p align="left">Utviklingsminister, Utenriksdepartementet, Jens Stoltenbergs andre regjering</p></td></tr>
<tr>
<td class="contents" valign="top" width="140">
<p align="left">1997-2001</p></td>
<td class="contents" valign="top" width="455">
<p align="left">Stortingsrepresentant for Oslo</p></td></tr>
<tr>
<td class="contents" valign="top" width="140">
<p align="left">1993-1997</p></td>
<td class="contents" valign="top" width="455">
<p align="left">Stortingsrepresentant for Oslo</p></td></tr>
<tr>
<td class="contents" valign="top" width="140">
<p align="left">1989-1993</p></td>
<td class="contents" valign="top" width="455">
<p align="left">Stortingsrepresentant for Sør-Trøndelag</p></td></tr>
<tr>
<td class="contents" valign="top" width="140">
<p align="left">1987-1997</p></td>
<td class="contents" valign="top" width="455">
<p align="left">Leder for Sosialistisk Venstreparti</p></td></tr>
<tr>
<td class="contents" valign="top" width="140">
<p align="left">1985-1987</p></td>
<td class="contents" valign="top" width="455">
<p align="left">Medlem i Sosialistisk Venstrepartis hovedstyre</p></td></tr>
<tr>
<td class="contents" valign="top" width="140">
<p align="left">1981-1985</p></td>
<td class="contents" valign="top" width="455">
<p align="left">Partisekretær for Sosialistisk Venstreparti</p></td></tr>
<tr>
