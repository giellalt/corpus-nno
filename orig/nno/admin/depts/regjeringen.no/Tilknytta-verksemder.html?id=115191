            </a>
            <div class="ArticleImgContent">
                <h2>
                    <a href="/nn/dep/bld/dep/tilknyttede-virksomheter/helsedirektoratet.html?id=511800" title="">
                        Helsedirektoratet
                    </a>
                </h2>
                <h3 class="subDescription" style="display:none"></h3>
                
                <p>Helsedirektoratet er et fagdirektorat og en del av den sentrale sosial- og helseforvaltningen.</p>
                
                
                <p>
                    <a href="http://www.shdir.no" class="externalLink" target="_blank">
                    Nettsida til   Helsedirektoratet</a>
                    
                </p>
                                 
           </div>
        </div> 
    
        <div class="ArticleView"> 
            <a href="/nn/dep/bld/dep/tilknyttede-virksomheter/integrerings--og-mangfoldsdirektoratet-i.html?id=589607" class="ISI_IGNORE">
