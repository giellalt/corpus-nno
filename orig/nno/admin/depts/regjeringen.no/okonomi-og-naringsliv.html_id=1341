        <div class="ArticleView"> 
            <a href="/nn/dep/fin/pressesenter/pressemeldinger/2010/regjeringens-forslag-til-skatte--og-avgi.html?id=619649" class="ISI_IGNORE">
                <img src="/Upload/FIN/Ingresssbilder/budsjett_ingress.gif" alt="Illustrasjonsbilde" class="ArticleImg" />
